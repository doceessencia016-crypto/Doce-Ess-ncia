# Copie este arquivo para ".env" (mesma pasta) e preencha com os valores reais.
# O .env NUNCA deve ser commitado nem colado no chat — já está no .gitignore.

# Project Settings -> API -> Project URL
VITE_SUPABASE_URL=

# Project Settings -> API -> Project API keys -> anon public
# Pode ser exposta no frontend (protegida pelas regras RLS do banco)
VITE_SUPABASE_ANON_KEY=

# Project Settings -> API -> Project API keys -> service_role
# NUNCA usar no frontend. Só no backend (Vercel Functions). Dá acesso total ao banco.
SUPABASE_SERVICE_ROLE_KEY=
